# Copy to .env.local for dev, and set the same in Vercel for production.

# Which chain the staking UI targets: "mainnet" or anything else for Sepolia testnet
NEXT_PUBLIC_CHAIN=testnet

# Reown (WalletConnect) project id
NEXT_PUBLIC_REOWN_PROJECT_ID=0b1cfff79855c73f2ec77409f402908b

# Supabase (from Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret   # server only, never expose

# Relayer wallet that calls declareResult (server only). Fund it with a little CELO.
RELAYER_PRIVATE_KEY=0xyour-relayer-private-key
